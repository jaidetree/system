# Configure git to use personal SSH key (not Snowflake's sf __ssh)
# This automatically applies when entering the system repo directory
export GIT_SSH_COMMAND="/usr/bin/ssh -i $HOME/.ssh/id_ed_personal"
export GIT_AUTHOR_NAME="jaide"
export GIT_AUTHOR_EMAIL="jayzawrotny@gmail.com"
export GIT_COMMITTER_NAME="jaide"
export GIT_COMMITTER_EMAIL="jayzawrotny@gmail.com"
